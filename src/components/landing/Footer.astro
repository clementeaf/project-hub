<footer class="border-t border-border bg-muted/30">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 sm:py-12 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 text-lg font-bold">
          <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-primary text-primary-foreground text-xs font-bold sm:h-8 sm:w-8 sm:text-sm">
            P
          </div>
          ProjectHub
        </a>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Consultoría y desarrollo de software personalizado para hacer realidad tus proyectos digitales.
        </p>
      </div>

      <!-- Links - Services -->
      <div>
        <h3 class="text-sm font-semibold">Servicios</h3>
        <ul class="mt-3 space-y-2">
          <li><a href="/#servicios" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Desarrollo Web</a></li>
          <li><a href="/#servicios" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Consultoría Técnica</a></li>
          <li><a href="/#servicios" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Diseño UI/UX</a></li>
          <li><a href="/#servicios" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Soporte</a></li>
        </ul>
      </div>

      <!-- Links - Company -->
      <div>
        <h3 class="text-sm font-semibold">Empresa</h3>
        <ul class="mt-3 space-y-2">
          <li><a href="/#proceso" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Proceso</a></li>
          <li><a href="/#testimonios" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Testimonios</a></li>
          <li><a href="/contacto" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Contacto</a></li>
          <li><a href="/agendar" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Agendar Consulta</a></li>
        </ul>
