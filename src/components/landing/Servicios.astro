---

<section id="servicios" class="py-16 sm:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl lg:text-4xl">
        Nuestros Servicios
      </h2>
      <p class="mt-3 text-base text-muted-foreground sm:mt-4 sm:text-lg">
        Soluciones integrales para cada etapa de tu proyecto digital
      </p>
    </div>

    <div class="mx-auto mt-10 grid max-w-5xl gap-4 sm:mt-16 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
      {servicios.map((servicio) => (
        <div class="group relative rounded-xl border border-border bg-card p-5 transition-all hover:border-foreground/20 hover:shadow-md sm:p-6">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 sm:mb-4 sm:h-12 sm:w-12">
            <svg class="h-5 w-5 text-primary sm:h-6 sm:w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <Fragment set:html={servicio.icon} />
            </svg>
          </div>
          <h3 class="text-base font-semibold sm:text-lg">{servicio.title}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground sm:mt-2">{servicio.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
