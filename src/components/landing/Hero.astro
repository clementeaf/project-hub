---
---

<section class="relative overflow-hidden px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-40">
  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(45%_40%_at_50%_60%,rgba(120,119,198,0.08),transparent)]"></div>

  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-border bg-muted/50 px-3 py-1 text-xs sm:mb-6 sm:px-4 sm:py-1.5 sm:text-sm text-muted-foreground">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
        </span>
        Disponibles para nuevos proyectos
      </div>

      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl lg:text-6xl">
        Transformamos tus ideas en
        <span class="bg-gradient-to-r from-chart-1 to-chart-5 bg-clip-text text-transparent">
          soluciones digitales
        </span>
      </h1>

      <p class="mt-4 text-base leading-7 text-muted-foreground sm:mt-6 sm:text-lg sm:leading-8 lg:text-xl">
        Consultoría y desarrollo de software personalizado. Trabajamos contigo desde la
        concepción hasta la entrega, con total transparencia en cada etapa del proceso.
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:mt-10 sm:flex-row sm:gap-4">
        <a
          href="/agendar"
          class="inline-flex h-11 w-full items-center justify-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow-md transition-all hover:bg-primary/90 hover:shadow-lg sm:h-12 sm:w-auto sm:px-8"
        >
          Agendar Consulta Gratuita
        </a>
        <a
          href="/#servicios"
          class="inline-flex h-11 w-full items-center justify-center rounded-md border border-input bg-background px-6 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground sm:h-12 sm:w-auto sm:px-8"
        >
          Ver Servicios
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-12 grid grid-cols-2 gap-4 sm:mt-16 sm:gap-8 sm:grid-cols-4">
        <div>
          <div class="text-2xl font-bold sm:text-3xl">50+</div>
          <div class="mt-0.5 text-xs text-muted-foreground sm:mt-1 sm:text-sm">Proyectos Entregados</div>
        </div>
        <div>
          <div class="text-2xl font-bold sm:text-3xl">98%</div>
          <div class="mt-0.5 text-xs text-muted-foreground sm:mt-1 sm:text-sm">Clientes Satisfechos</div>
        </div>
        <div>
          <div class="text-2xl font-bold sm:text-3xl">5+</div>
          <div class="mt-0.5 text-xs text-muted-foreground sm:mt-1 sm:text-sm">Años de Experiencia</div>
        </div>
        <div>
          <div class="text-2xl font-bold sm:text-3xl">24/7</div>
          <div class="mt-0.5 text-xs text-muted-foreground sm:mt-1 sm:text-sm">Soporte Continuo</div>
        </div>
      </div>
    </div>
  </div>
</section>
