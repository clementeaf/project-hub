---
const testimonios = [
  {
    name: "María González",
    role: "CEO, TechStart",
    avatar: "MG",
    text: "ProjectHub transformó nuestra idea en una plataforma funcional en tiempo récord. La transparencia del proceso y la calidad del código superaron nuestras expectativas.",
    rating: 5
  },
  {
    name: "Carlos Mendoza",
    role: "CTO, DataFlow",
    avatar: "CM",
    text: "La consultoría técnica que recibimos fue invaluable. Nos ayudaron a elegir el stack correcto y a diseñar una arquitectura escalable desde el inicio.",
    rating: 5
  },
  {
    name: "Ana Rodríguez",
    role: "Product Manager, EcoShop",
    avatar: "AR",
    text: "El dashboard de seguimiento nos permitió estar al tanto de cada avance. Poder comentar y aprobar entregables directamente fue un game-changer.",
    rating: 5
  },
  {
    name: "Diego Fernández",
    role: "Founder, FinTrack",
    avatar: "DF",
    text: "Excelente equipo. Cumplieron con cada hito del proyecto y el soporte post-entrega ha sido excepcional. Totalmente recomendados.",
    rating: 5
  }
]
---

<section id="testimonios" class="py-16 sm:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl lg:text-4xl">
        Lo que dicen nuestros clientes
      </h2>
      <p class="mt-3 text-base text-muted-foreground sm:mt-4 sm:text-lg">
        Historias de éxito de quienes confiaron en nosotros
      </p>
    </div>

    <div class="mx-auto mt-10 grid max-w-5xl gap-4 sm:mt-16 sm:grid-cols-2 sm:gap-6">
      {testimonios.map((t) => (
        <div class="rounded-xl border border-border bg-card p-5 sm:p-6">
          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="h-4 w-4 fill-chart-4 text-chart-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z" clip-rule="evenodd" />
              </svg>
            ))}
          </div>

          <p class="mt-3 text-sm leading-relaxed text-muted-foreground sm:mt-4">"{t.text}"</p>

          <div class="mt-4 flex items-center gap-3 sm:mt-6">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary text-xs font-medium text-primary-foreground sm:h-10 sm:w-10">
              {t.avatar}
            </div>
            <div class="min-w-0">
              <div class="truncate text-sm font-semibold">{t.name}</div>
              <div class="truncate text-xs text-muted-foreground">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
