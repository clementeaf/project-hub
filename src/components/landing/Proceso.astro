---

<section id="proceso" class="bg-muted/30 py-16 sm:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl lg:text-4xl">
        Nuestro Proceso
      </h2>
      <p class="mt-3 text-base text-muted-foreground sm:mt-4 sm:text-lg">
        Un enfoque estructurado y transparente en cada etapa
      </p>
    </div>

    <div class="mx-auto mt-10 max-w-4xl sm:mt-16">
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-5 top-0 hidden h-full w-px bg-border sm:left-6 sm:block"></div>

        <div class="space-y-8 sm:space-y-12">
          {pasos.map((paso, i) => (
            <div class="relative flex gap-4 sm:gap-8">
              <!-- Circle -->
              <div class="relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border-2 border-primary bg-background text-xs font-bold text-primary sm:h-12 sm:w-12 sm:text-sm">
                {paso.number}
              </div>

              <div class="min-w-0 pb-2">
                <div class="flex items-center gap-2 sm:gap-3">
                  <svg class="hidden h-5 w-5 text-muted-foreground sm:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <Fragment set:html={paso.icon} />
                  </svg>
                  <h3 class="text-lg font-semibold sm:text-xl">{paso.title}</h3>
                </div>
                <p class="mt-1.5 text-sm text-muted-foreground sm:mt-2 sm:text-base">{paso.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
