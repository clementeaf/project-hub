---
import LandingLayout from '../layouts/LandingLayout.astro'
import AgendarForm from '../components/landing/AgendarForm.tsx'
---

<LandingLayout title="Agendar Consulta">
  <section class="py-16 sm:py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="text-center">
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl lg:text-4xl">Agendar Consulta Gratuita</h1>
          <p class="mt-3 text-base text-muted-foreground sm:mt-4 sm:text-lg">
            Selecciona una fecha y hora para una videollamada de 30 minutos donde evaluaremos tu proyecto.
          </p>
        </div>

        <div class="mt-8 sm:mt-12">
          <AgendarForm client:load />
        </div>

        <div class="mt-8 rounded-lg border border-border bg-muted/30 p-4 text-center text-sm text-muted-foreground">
          <p>La consulta es <strong class="text-foreground">100% gratuita</strong> y sin compromiso. Duración: 30 minutos por videollamada.</p>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
