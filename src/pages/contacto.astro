---
import LandingLayout from '../layouts/LandingLayout.astro'
import ContactForm from '../components/landing/ContactForm.tsx'
---

<LandingLayout title="Contacto">
  <section class="py-16 sm:py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl">
        <div class="text-center">
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl lg:text-4xl">Contacto</h1>
          <p class="mt-3 text-base text-muted-foreground sm:mt-4 sm:text-lg">
            ¿Tienes un proyecto en mente? Escríbenos y conversemos.
          </p>
        </div>

        <div class="mt-8 rounded-xl border border-border bg-card p-4 sm:mt-12 sm:p-6 md:p-8">
          <ContactForm client:load />
        </div>

        <div class="mt-8 grid gap-6 sm:mt-12 sm:grid-cols-3">
          <div class="text-center">
            <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <div class="text-sm font-medium">Email</div>
            <div class="mt-1 text-sm text-muted-foreground">hola@projecthub.dev</div>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </div>
            <div class="text-sm font-medium">Teléfono</div>
            <div class="mt-1 text-sm text-muted-foreground">+1 (555) 123-4567</div>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <div class="text-sm font-medium">Ubicación</div>
            <div class="mt-1 text-sm text-muted-foreground">Remoto / Global</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
