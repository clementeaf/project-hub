---
import AppLayout from '../../layouts/AppLayout.astro'
import Sidebar from '../../components/app/Sidebar.tsx'
import Header from '../../components/app/Header.tsx'
import DashboardOverview from '../../components/app/DashboardOverview.tsx'
---

<AppLayout title="Dashboard">
  <div class="flex h-screen">
    <Sidebar client:load currentPath="/app" />
    <div class="flex flex-1 flex-col overflow-hidden">
      <Header client:load breadcrumb={[{ label: "Dashboard" }]} />
      <main class="flex-1 overflow-y-auto">
        <DashboardOverview client:load />
      </main>
    </div>
  </div>
</AppLayout>
