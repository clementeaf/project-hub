---
import AppLayout from '../../../layouts/AppLayout.astro'
import Sidebar from '../../../components/app/Sidebar.tsx'
import Header from '../../../components/app/Header.tsx'
import ProjectDetail from '../../../components/app/ProjectDetail.tsx'

const { id } = Astro.params

export function getStaticPaths() {
  return [
    { params: { id: '1' } },
    { params: { id: '2' } },
    { params: { id: '3' } },
    { params: { id: '4' } },
    { params: { id: '5' } },
  ]
}
---

<AppLayout title="Proyecto">
  <div class="flex h-screen">
    <Sidebar client:load currentPath="/app/proyectos" />
    <div class="flex flex-1 flex-col overflow-hidden">
      <Header client:load breadcrumb={[
        { label: "Dashboard", href: "/app" },
        { label: "Proyectos", href: "/app/proyectos" },
        { label: `Proyecto #${id}` }
      ]} />
      <main class="flex-1 overflow-y-auto">
        <ProjectDetail client:load projectId={id!} />
      </main>
    </div>
  </div>
</AppLayout>
