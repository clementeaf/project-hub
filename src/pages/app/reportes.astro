---
import AppLayout from '../../layouts/AppLayout.astro'
import Sidebar from '../../components/app/Sidebar.tsx'
import Header from '../../components/app/Header.tsx'
---

<AppLayout title="Reportes">
  <div class="flex h-screen">
    <Sidebar client:load currentPath="/app/reportes" />
    <div class="flex flex-1 flex-col overflow-hidden">
      <Header client:load breadcrumb={[{ label: "Dashboard", href: "/app" }, { label: "Reportes" }]} />
      <main class="flex-1 overflow-y-auto p-6">
        <div class="space-y-6">
          <div>
            <h1 class="text-2xl font-bold">Reportes</h1>
            <p class="text-sm text-muted-foreground">Métricas y estadísticas de los proyectos</p>
          </div>

          <!-- Metrics summary -->
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-xl border border-border bg-card p-5">
              <div class="text-sm text-muted-foreground">Tareas Totales</div>
              <div class="mt-1 text-3xl font-bold">148</div>
              <div class="mt-1 text-xs text-chart-2">+12 esta semana</div>
            </div>
            <div class="rounded-xl border border-border bg-card p-5">
              <div class="text-sm text-muted-foreground">Completadas</div>
              <div class="mt-1 text-3xl font-bold">93</div>
              <div class="mt-1 text-xs text-chart-2">62.8% del total</div>
            </div>
            <div class="rounded-xl border border-border bg-card p-5">
              <div class="text-sm text-muted-foreground">En Progreso</div>
              <div class="mt-1 text-3xl font-bold">32</div>
              <div class="mt-1 text-xs text-chart-4">21.6% del total</div>
            </div>
            <div class="rounded-xl border border-border bg-card p-5">
              <div class="text-sm text-muted-foreground">Bugs Abiertos</div>
              <div class="mt-1 text-3xl font-bold">7</div>
              <div class="mt-1 text-xs text-destructive">3 críticos</div>
            </div>
          </div>

          <div class="grid gap-6 lg:grid-cols-2">
            <!-- Burndown chart placeholder -->
            <div class="rounded-xl border border-border bg-card p-5">
              <h2 class="mb-4 text-lg font-semibold">Burndown Chart</h2>
              <div class="flex h-64 items-center justify-center rounded-lg bg-muted/50">
                <div class="text-center">
                  <svg class="mx-auto h-12 w-12 text-muted-foreground/40" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                  </svg>
                  <p class="mt-2 text-sm text-muted-foreground">Gráfico de burndown</p>
                  <p class="text-xs text-muted-foreground">(Visualización placeholder)</p>
                </div>
              </div>
            </div>

            <!-- Distribution by status -->
            <div class="rounded-xl border border-border bg-card p-5">
              <h2 class="mb-4 text-lg font-semibold">Distribución por Estado</h2>
              <div class="space-y-3">
                {[
                  { label: "Backlog", count: 23, pct: 15.5, color: "bg-gray-400" },
                  { label: "En Progreso", count: 32, pct: 21.6, color: "bg-blue-500" },
                  { label: "Review", count: 15, pct: 10.1, color: "bg-yellow-500" },
                  { label: "QA", count: 8, pct: 5.4, color: "bg-purple-500" },
                  { label: "Completado", count: 93, pct: 62.8, color: "bg-green-500" },
                ].map((item) => (
                  <div>
                    <div class="mb-1 flex items-center justify-between text-sm">
                      <div class="flex items-center gap-2">
                        <div class={`h-2.5 w-2.5 rounded-full ${item.color}`}></div>
                        <span>{item.label}</span>
                      </div>
                      <span class="text-muted-foreground">{item.count} ({item.pct}%)</span>
                    </div>
                    <div class="h-1.5 overflow-hidden rounded-full bg-secondary">
                      <div class={`h-full rounded-full ${item.color}`} style={`width: ${item.pct}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Distribution by type -->
            <div class="rounded-xl border border-border bg-card p-5">
              <h2 class="mb-4 text-lg font-semibold">Distribución por Tipo</h2>
              <div class="space-y-3">
                {[
                  { label: "Tasks", count: 85, pct: 57.4, color: "bg-blue-500" },
                  { label: "Features", count: 42, pct: 28.4, color: "bg-purple-500" },
                  { label: "Bugs", count: 21, pct: 14.2, color: "bg-red-500" },
                ].map((item) => (
                  <div>
                    <div class="mb-1 flex items-center justify-between text-sm">
                      <div class="flex items-center gap-2">
                        <div class={`h-2.5 w-2.5 rounded-full ${item.color}`}></div>
                        <span>{item.label}</span>
                      </div>
                      <span class="text-muted-foreground">{item.count} ({item.pct}%)</span>
                    </div>
                    <div class="h-1.5 overflow-hidden rounded-full bg-secondary">
                      <div class={`h-full rounded-full ${item.color}`} style={`width: ${item.pct}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Team velocity -->
            <div class="rounded-xl border border-border bg-card p-5">
              <h2 class="mb-4 text-lg font-semibold">Velocidad del Equipo</h2>
              <div class="space-y-4">
                {[
                  { name: "Juan Díaz", initials: "JD", completed: 18, inProgress: 3 },
                  { name: "María López", initials: "ML", completed: 15, inProgress: 4 },
                  { name: "Carlos Ruiz", initials: "CR", completed: 12, inProgress: 2 },
                  { name: "Ana Torres", initials: "AT", completed: 10, inProgress: 5 },
                  { name: "Pedro Gómez", initials: "PG", completed: 8, inProgress: 3 },
                ].map((member) => (
                  <div class="flex items-center gap-3">
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-muted text-xs font-medium">
                      {member.initials}
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between text-sm">
                        <span class="font-medium">{member.name}</span>
                        <span class="text-muted-foreground">{member.completed} completadas</span>
                      </div>
                      <div class="mt-1 h-1.5 overflow-hidden rounded-full bg-secondary">
                        <div class="h-full rounded-full bg-primary" style={`width: ${(member.completed / 20) * 100}%`}></div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>
</AppLayout>
